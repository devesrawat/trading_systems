# Copy this file to .env (local dev) or .env.prod (server)
# See docs/env-variables.adoc for full documentation

# -- Data provider: "kite" (default) | "upstox"
DATA_PROVIDER=kite

# -- Zerodha Kite (required when DATA_PROVIDER=kite)
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
KITE_ACCESS_TOKEN=            # generated daily by main.py --login

# -- Upstox v2 (required when DATA_PROVIDER=upstox)
# Install extra dep:  uv sync --extra upstox
# Instrument keys:    https://assets.upstox.com/market-quote/instruments/exchange/NSE.csv.gz
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=          # generated daily via OAuth  (see data/providers/upstox.py)
UPSTOX_REDIRECT_URI=http://localhost:8080

# -- Database
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=nse_trading
TIMESCALE_URL=postgresql://trader:change_me_in_prod@localhost:5432/nse_trading
REDIS_URL=redis://localhost:6379/0

# -- News APIs (optional)
FINNHUB_API_KEY=
NEWSAPI_KEY=

# -- Monitoring
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MLFLOW_TRACKING_URI=http://localhost:5001

# -- Grafana (prod only)
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_ROOT_URL=https://your-domain.com/grafana/

# -- Strategy
SIGNAL_THRESHOLD=0.65
MAX_POSITION_PCT=0.02
DAILY_DD_LIMIT=0.03
WEEKLY_DD_LIMIT=0.07
PAPER_TRADE_MODE=true
